# Copy this file to ".env" (or set these as Environment Variables in your
# hosting provider's dashboard — Render, Railway, etc.)

# Port the service listens on. Most hosts (Render, Railway) set this
# automatically — you usually don't need to touch it.
PORT=3000

# REQUIRED: a long, random secret that protects the admin endpoints
# (approving/revoking a client's Digital Business Card package).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=change-this-to-a-long-random-string

# STRONGLY RECOMMENDED — without this, every card is lost whenever
# this service restarts (which Render's free tier does often; see
# "MAKING CARDS PERMANENT" in README-DEPLOY.md for the 5-minute,
# free fix using MongoDB Atlas).
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/
